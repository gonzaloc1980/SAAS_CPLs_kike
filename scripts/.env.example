# Credenciales Hotmart
HOTMART_EMAIL=tu_email@ejemplo.com
HOTMART_PASSWORD=tu_contraseña

# Puerto del servidor local (opcional, por defecto 3001)
PORT=3001

# Supabase - para guardar los datos en la base de datos
# Consigue estos valores en: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
